<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.SagerNet" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorPrimary">@color/stk_primary</item>
        <item name="colorPrimaryDark">@color/stk_primary_dark</item>
        <item name="colorAccent">@color/stk_accent</item>
        <item name="colorMaterial100">@color/material_light_blue_100</item>
        <item name="colorMaterial300">@color/material_light_blue_300</item>
        <item name="android:statusBarColor">@color/stk_primary_dark</item>
        <item name="android:navigationBarColor">@color/black</item>
    </style>

    <style name="Theme.SagerNet.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="colorPrimary">@color/stk_primary</item>
        <item name="colorPrimaryDark">@color/stk_primary_dark</item>
        <item name="colorAccent">@color/stk_accent</item>
