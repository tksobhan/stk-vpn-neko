        <item name="colorMaterial300">@color/material_light_blue_300</item>
    </style>

    <style name="Theme.SagerNet.AlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog"/>
    <style name="Theme.SagerNet.BottomSheetDialog" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog"/>

    <style name="Widget.SagerNet.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/chip_background</item>
        <item name="chipStrokeColor">@color/stk_primary</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="rippleColor">@color/chip_ripple_color</item>
        <item name="android:textColor">@color/chip_text_color</item>
    </style>

    <style name="Widget.SagerNet.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/stk_primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

